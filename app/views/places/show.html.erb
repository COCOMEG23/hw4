<h1><%= @place["name"] %></h1>

<a href="/places" class="btn btn-secondary mb-3">← Back to All Places</a>

<% if @current_user %>
  <p>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
  </p>
<% end %>

<h2>My Entries</h2>
<div class="row">
  <% for entry in @entries %>
    <div class="col-12 col-md-6 col-lg-4 mb-3">
      <div class="card h-100">
        <% if entry.uploaded_image.attached? %>
          <img src="<%= url_for(entry.uploaded_image) %>" class="card-img-top" alt="<%= entry["title"] %>">
        <% end %>
        <div class="card-body">
          <h5 class="card-title"><%= entry["title"] %></h5>
          <h6 class="card-subtitle mb-2 text-muted"><%= entry["occurred_on"] %></h6>
          <p class="card-text"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>